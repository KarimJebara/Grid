{
  "name": "terminal-grid",
  "version": "2.0.0",
  "description": "Dynamic grid of terminal emulators backed by persistent user sessions",
  "main": "out/main/index.js",
  "author": "karim",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --mac --config electron-builder.json",
    "package:mac": "electron-vite build && electron-builder --mac --config electron-builder.json --publish never",
    "package:win": "electron-vite build && electron-builder --win --config electron-builder.json --publish never",
    "package:dir": "electron-vite build && electron-builder --mac --dir --config electron-builder.json",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
